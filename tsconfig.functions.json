{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": []
  },
  "include": [
    "supabase/functions/**/*.ts",
    "supabase/functions/**/*.d.ts"
  ],
  "exclude": [
    "supabase/functions/**/node_modules"
  ]
}
